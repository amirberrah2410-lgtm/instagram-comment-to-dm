# انسخ هذا الملف باسم .env محليًا للاختبار، وفي Netlify أضفها من:
# Site settings -> Environment variables

# كلمة سر تختارها أنت بنفسك (أي نص عشوائي)، تُستخدم فقط للتحقق من صحة الـ Webhook عند ربطه بـ Meta
IG_VERIFY_TOKEN=choose_any_random_string_here

# Access Token الخاص بصفحة Facebook المرتبطة بحساب Instagram Business/Creator
# يُنشأ من Meta for Developers -> App -> Instagram -> Generate Token
IG_PAGE_ACCESS_TOKEN=your_page_access_token_here

# الكلمة المفتاحية التي يجب أن يكتبها المستخدم في التعليق
IG_KEYWORD=رابط

# نص الرسالة التي سيتم إرسالها تلقائيًا (ضع رابطك هنا)
IG_LINK_MESSAGE=تفضل الرابط: https://example.com
